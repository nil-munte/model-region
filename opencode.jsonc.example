{
  "$schema": "https://opencode.ai/config.json",
  
  // GitHub MCP Server - Enables automated GitHub operations
  // To enable: run "opencode mcp auth github" then set enabled: true
  // Copy this file to opencode.jsonc and configure as needed
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false
    }
  },
  
  // Global tool permissions (applies to all agents unless overridden)
  "tools": {
    // Enable GitHub MCP tools globally
    "github_*": true
  }
}
